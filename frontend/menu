#!/data/data/com.termux/files/usr/bin/bash
# menu — gum-based TUI for the portable-pivot frontend on Fold 6.
# Single entry point you can launch by hand or from Termux:Widget.

set -u
FRONTEND_DIR="$(cd "$(dirname "$0")" && pwd)"
SOCKS_PORT="9050"
KADX_PORT="2222"
KADX_USER="kadx"
KADX_KEY="$HOME/.ssh/id_ed25519"

# Ensure gum is available
if ! command -v gum >/dev/null 2>&1; then
    echo "gum not installed. Run: pkg install gum"
    exit 1
fi

# Find the active pivot host (if pivot-up.sh is running)
active_pivot_host() {
    pgrep -af "autossh.*-R[ =]?${SOCKS_PORT}:.*${KADX_USER}@" 2>/dev/null \
        | sed -n "s/.* ${KADX_USER}@\([^ ]*\).*/\1/p" | head -1
}

show_status() {
    HOST=$(active_pivot_host)
    if [ -n "$HOST" ]; then
        gum style --foreground 42 "● Pivot UP — tunnel via ${HOST}"
        gum style --foreground 240 "  Phone microsocks: $(pgrep -fx "microsocks -i 127.0.0.1 -p $SOCKS_PORT" >/dev/null && echo running || echo NOT running)"
    else
        gum style --foreground 196 "● Pivot DOWN — start with 'Start pivot' below"
    fi
}

run_remote() {
    HOST=$(active_pivot_host)
    if [ -z "$HOST" ]; then
        gum style --foreground 196 "No active pivot. Choose 'Start pivot' first."
        gum input --placeholder "Press Enter to return" > /dev/null
        return
    fi
    ssh -p "$KADX_PORT" -i "$KADX_KEY" -o StrictHostKeyChecking=accept-new \
        "${KADX_USER}@${HOST}" "$1"
    echo ""
    gum input --placeholder "Press Enter to return" > /dev/null
}

scan_current_lan() {
    bash "$FRONTEND_DIR/scan-here"
    gum input --placeholder "Press Enter to return" > /dev/null
}

scan_specific_host() {
    HOST_TGT=$(gum input --placeholder "Host or CIDR to scan (e.g. 192.168.1.42)")
    [ -z "$HOST_TGT" ] && return
    PORTS=$(gum input --value "22,80,443,445,3389,8080,8443" --placeholder "Ports")
    run_remote "pivot nmap -T4 -p ${PORTS} ${HOST_TGT}"
}

view_recent_logs() {
    run_remote "ls -lat ~/pivot-logs/$(date +%Y-%m-%d)/ 2>/dev/null | head -15; echo; echo 'Latest:'; tail -20 ~/pivot-logs/latest.log 2>/dev/null"
}

start_pivot() {
    if [ -n "$(active_pivot_host)" ]; then
        gum style --foreground 220 "Pivot already up."
        gum input --placeholder "Press Enter to return" > /dev/null
        return
    fi
    gum style --foreground 42 "Starting pivot — this will replace this menu with a kadx shell."
    gum style --foreground 240 "Exit the shell or close Termux to return."
    sleep 1
    exec bash "$FRONTEND_DIR/pivot-up.sh"
}

stop_pivot() {
    if gum confirm "Stop pivot? (kills autossh + microsocks)"; then
        pkill -f autossh 2>/dev/null
        pkill -x microsocks 2>/dev/null
        gum style --foreground 196 "Pivot torn down."
        sleep 1
    fi
}

# Main loop
while true; do
    clear
    gum style --border normal --padding "1 2" --margin "1" --border-foreground 212 \
        "Kali Portable Pivot — Fold 6 frontend"
    show_status
    echo ""
    CHOICE=$(gum choose \
        "Start pivot (open kadx shell)" \
        "Scan current Wi-Fi network" \
        "Scan specific host/CIDR" \
        "View recent logs" \
        "Pivot status (detail)" \
        "Stop pivot" \
        "Quit")
    case "$CHOICE" in
        "Start pivot (open kadx shell)") start_pivot ;;
        "Scan current Wi-Fi network")    scan_current_lan ;;
        "Scan specific host/CIDR")       scan_specific_host ;;
        "View recent logs")              view_recent_logs ;;
        "Pivot status (detail)")         run_remote "bash ~/pivot-status.sh" ;;
        "Stop pivot")                    stop_pivot ;;
        "Quit"|"")                       clear; exit 0 ;;
    esac
done
