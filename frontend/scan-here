#!/data/data/com.termux/files/usr/bin/bash
# scan-here — auto-detect phone's current Wi-Fi subnet, run nmap via pivot,
# log to kadx. Uses termux-wifi-connectioninfo because Termux's Android
# sandbox blocks `ip addr` / `ifconfig` / /proc/net/route.

set -u
SOCKS_PORT="9050"

# --- detect phone's current Wi-Fi subnet ----------------------------------
if ! command -v termux-wifi-connectioninfo >/dev/null 2>&1; then
    cat <<EOF
ERROR: termux-wifi-connectioninfo not found.
  Install:  pkg install termux-api
  Also install the Termux:API Android app from F-Droid (separate from the pkg).
EOF
    exit 1
fi

WIFI_JSON=$(termux-wifi-connectioninfo 2>&1)
PHONE_IP=$(echo "$WIFI_JSON" | awk -F'"' '/"ip":/{print $4}')

if [ -z "$PHONE_IP" ] || [ "$PHONE_IP" = "<unknown>" ] || [ "$PHONE_IP" = "0.0.0.0" ]; then
    cat <<EOF
ERROR: couldn't get a Wi-Fi IP from termux-wifi-connectioninfo.
  Is the phone connected to Wi-Fi (not cellular)? Termux:API app installed?

Raw termux-wifi-connectioninfo output:
EOF
    echo "$WIFI_JSON" | head -20
    exit 1
fi

# Build /24 from the phone IP (most home / cafe LANs are /24)
NET_PREFIX="${PHONE_IP%.*}"
NETWORK="${NET_PREFIX}.0/24"

# --- confirm tunnel is up ------------------------------------------------
if ! pgrep -af "autossh.*-R[ =]?${SOCKS_PORT}:.*kadx@" >/dev/null 2>&1 \
   && ! pgrep -af "ssh.*-R[ =]?${SOCKS_PORT}:.*kadx@" >/dev/null 2>&1; then
    cat <<EOF
ERROR: no active pivot tunnel detected.
  Start the pivot first:
    - via menu: 'Start pivot'
    - or directly:  ~/portable-pivot/frontend/pivot-up.sh
EOF
    exit 2
fi

# --- pick our OWN SSH target (don't trust autossh's choice — may not be ---
# --- reachable from the same network state right now) --------------------
KADX_PORT="2222"
KADX_USER="kadx"
KADX_KEY="$HOME/.ssh/id_ed25519"
KADX_TARGETS=("100.105.140.70" "192.168.1.165")

TUNNEL_HOST=""
for t in "${KADX_TARGETS[@]}"; do
    if timeout 4 bash -c "exec 3<>/dev/tcp/$t/$KADX_PORT" 2>/dev/null; then
        TUNNEL_HOST="$t"
        break
    fi
done
if [ -z "$TUNNEL_HOST" ]; then
    cat <<EOF
ERROR: pivot tunnel is up, but no kadx target is reachable from here for the SSH session.
  Tried: ${KADX_TARGETS[*]}
  Phone may be on a network where neither Tailscale routes nor home LAN work.
EOF
    exit 3
fi
TS=$(date +%Y%m%d-%H%M%S)
LOG_REL="pivot-logs/$(date +%Y-%m-%d)/${TS}-scan-${NETWORK//\//_}.log"

cat <<EOF
==> scan-here
    phone IP    : $PHONE_IP
    target net  : $NETWORK
    pivot host  : $TUNNEL_HOST
    log on kadx : ~/$LOG_REL

    Streaming nmap output (TCP connect scan via SOCKS5 pivot):

EOF

ssh -p "$KADX_PORT" -i "$KADX_KEY" -o StrictHostKeyChecking=accept-new \
    "$KADX_USER@$TUNNEL_HOST" \
    "mkdir -p ~/pivot-logs/$(date +%Y-%m-%d) && \
     \$HOME/.local/bin/pivot nmap -T4 -p 22,80,443,445,3389,8080,8443 ${NETWORK} 2>&1 \
       | tee ~/${LOG_REL} && \
     ln -sf ~/${LOG_REL} ~/pivot-logs/latest.log && \
     echo && echo '[scan-here] log saved: ~/${LOG_REL}'"
